{
   "name": "event-spaces-api",
   "version": "0.0.1",
   "description": "",
   "author": "",
   "private": true,
   "scripts": {
      "prebuild": "rimraf build",
      "build": "nest build",
      "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
      "start": "node build/main.js",
      "start:dev": "nest start -b swc -w",
      "start:debug": "nest start --debug --watch",
      "start:prod": "node dist/main",
      "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
      "test": "jest",
      "test:watch": "jest --watch",
      "test:cov": "jest --coverage",
      "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
      "test:e2e": "jest --config ./test/jest-e2e.json",
      "typeorm": "npm run build && typeorm-ts-node-esm -d ./build/config/ormconfig.js",
      "migration:generate": "npm run typeorm migration:generate -d src/migrations/$npm_config_name",
      "migration:create": "npx typeorm migration:create src/migrations/$npm_config_name",
      "migration:run": "npm run typeorm migration:run -- -t each ",
      "seed:run": "npm run build && typeorm-ts-node-esm -d ./build/config/seedsConfig.js migration:run",
      "migration:show": "npm run typeorm migration:show",
      "migration:revert": "npm run typeorm migration:revert"
   },
   "dependencies": {
      "@nestjs/axios": "3.0.2",
      "@nestjs/common": "^10.4.1",
      "@nestjs/config": "^3.2.3",
      "@nestjs/core": "^10.4.1",
      "@nestjs/jwt": "^10.2.0",
      "@nestjs/mapped-types": "*",
      "@nestjs/passport": "^10.0.3",
      "@nestjs/platform-express": "^10.4.1",
      "@nestjs/platform-socket.io": "^10.4.1",
      "@nestjs/serve-static": "^4.0.2",
      "@nestjs/swagger": "^7.4.0",
      "@nestjs/typeorm": "^10.0.2",
      "@nestjs/websockets": "^10.4.1",
      "@types/geojson": "^7946.0.14",
      "axios": "^1.7.4",
      "bcrypt": "^5.1.1",
      "bcryptjs": "^2.4.3",
      "class-transformer": "^0.5.1",
      "class-validator": "^0.14.1",
      "connect-redis": "^7.1.1",
      "csurf": "^1.11.0",
      "dayjs": "^1.11.12",
      "dotenv": "^16.4.5",
      "express-session": "^1.18.0",
      "futoin-hkdf": "^1.5.3",
      "geojson": "^0.5.0",
      "google-auth-library": "^9.13.0",
      "multer": "^1.4.5-lts.1",
      "mysql": "^2.18.1",
      "nestjs-typeorm-paginate": "^4.0.4",
      "passport": "^0.7.0",
      "passport-jwt": "^4.0.1",
      "passport-local": "^1.0.0",
      "passport-oauth": "^1.0.0",
      "pg": "^8.12.0",
      "pg-hstore": "^2.3.4",
      "redis": "^4.7.0",
      "reflect-metadata": "^0.2.2",
      "rimraf": "^6.0.1",
      "rxjs": "^7.8.1",
      "socket.io": "^4.7.5",
      "swagger-ui-express": "^5.0.1",
      "typeorm": "0.3.20"
   },
   "devDependencies": {
      "@eslint/eslintrc": "^3.1.0",
      "@eslint/js": "^9.9.1",
      "@nestjs/cli": "^10.4.4",
      "@nestjs/schematics": "^10.1.3",
      "@nestjs/testing": "^10.4.1",
      "@swc/cli": "^0.4.0",
      "@swc/core": "^1.7.10",
      "@types/bcryptjs": "^2.4.6",
      "@types/dotenv": "^8.2.0",
      "@types/express": "^4.17.21",
      "@types/jest": "29.5.12",
      "@types/multer": "^1.4.11",
      "@types/node": "^22.2.0",
      "@types/passport": "^1.0.16",
      "@types/passport-jwt": "^4.0.1",
      "@types/socket.io": "^3.0.2",
      "@types/supertest": "^6.0.2",
      "@typescript-eslint/eslint-plugin": "^8.1.0",
      "@typescript-eslint/parser": "^8.1.0",
      "eslint": "^9.9.0",
      "eslint-config-prettier": "^9.1.0",
      "eslint-plugin-prettier": "^5.2.1",
      "globals": "^15.9.0",
      "jest": "^29.7.0",
      "prettier": "^3.3.3",
      "source-map-support": "^0.5.21",
      "supertest": "^7.0.0",
      "ts-jest": "^29.2.4",
      "ts-loader": "^9.5.1",
      "ts-node": "10.9.2",
      "tsconfig-paths": "^4.2.0",
      "typescript": "5.5.4"
   },
   "jest": {
      "moduleFileExtensions": [
         "js",
         "json",
         "ts"
      ],
      "rootDir": "src",
      "testRegex": ".*\\.spec\\.ts$",
      "transform": {
         "^.+\\.(t|j)s$": "ts-jest"
      },
      "collectCoverageFrom": [
         "**/*.(t|j)s"
      ],
      "coverageDirectory": "../coverage",
      "testEnvironment": "node"
   }
}
