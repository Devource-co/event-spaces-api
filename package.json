{
   "name": "event-spaces-api",
   "version": "0.0.1",
   "description": "",
   "author": "",
   "private": true,
   "scripts": {
      "prebuild": "rimraf build",
      "build": "nest build",
      "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
      "start": "node build/main.js",
      "start:dev": "nest start -b swc -w",
      "start:debug": "nest start --debug --watch",
      "start:prod": "node dist/main",
      "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
      "test": "jest",
      "test:watch": "jest --watch",
      "test:cov": "jest --coverage",
      "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
      "test:e2e": "jest --config ./test/jest-e2e.json",
      "typeorm": "npm run build && typeorm-ts-node-esm -d ./build/config/ormconfig.js",
      "migration:generate": "npm run typeorm migration:generate -d src/migrations/$npm_config_name",
      "migration:create": "npx typeorm migration:create src/migrations/$npm_config_name",
      "migration:run": "npm run typeorm migration:run -- -t each ",
      "seed:run": "npm run build && typeorm-ts-node-esm -d ./build/config/seedsConfig.js migration:run",
      "migration:show": "npm run typeorm migration:show",
      "migration:revert": "npm run typeorm migration:revert"
   },
   "dependencies": {
      "@nestjs/axios": "^4.0.1",
      "@nestjs/common": "^11.1.6",
      "@nestjs/config": "^4.0.2",
      "@nestjs/core": "^11.1.6",
      "@nestjs/jwt": "^11.0.0",
      "@nestjs/mapped-types": "^2.1.0",
      "@nestjs/passport": "^11.0.5",
      "@nestjs/platform-express": "^11.1.6",
      "@nestjs/platform-socket.io": "^11.1.6",
      "@nestjs/serve-static": "^5.0.3",
      "@nestjs/swagger": "^11.2.0",
      "@nestjs/typeorm": "^11.0.0",
      "@nestjs/websockets": "^11.1.6",
      "@types/geojson": "^7946.0.16",
      "aws-sdk": "^2.1692.0",
      "axios": "^1.11.0",
      "bcrypt": "^6.0.0",
      "bcryptjs": "^3.0.2",
      "class-transformer": "^0.5.1",
      "class-validator": "^0.14.2",
      "connect-redis": "^9.0.0",
      "csurf": "^1.11.0",
      "dayjs": "^1.11.13",
      "dotenv": "^17.2.1",
      "express-session": "^1.18.2",
      "futoin-hkdf": "^1.5.3",
      "geojson": "^0.5.0",
      "google-auth-library": "^10.2.1",
      "multer": "^2.0.2",
      "mysql": "^2.18.1",
      "nestjs-typeorm-paginate": "^4.1.0",
      "passport": "^0.7.0",
      "passport-jwt": "^4.0.1",
      "passport-local": "^1.0.0",
      "passport-oauth": "^1.0.0",
      "pg": "^8.16.3",
      "pg-hstore": "^2.3.4",
      "redis": "^5.8.1",
      "reflect-metadata": "^0.2.2",
      "rimraf": "^6.0.1",
      "rxjs": "^7.8.2",
      "socket.io": "^4.8.1",
      "swagger-ui-express": "^5.0.1",
      "typeorm": "^0.3.25"
   },
   "devDependencies": {
      "@eslint/eslintrc": "^3.3.1",
      "@eslint/js": "^9.33.0",
      "@nestjs/cli": "^11.0.10",
      "@nestjs/schematics": "^11.0.7",
      "@nestjs/testing": "^11.1.6",
      "@swc/cli": "^0.7.8",
      "@swc/core": "^1.13.3",
      "@types/bcryptjs": "^3.0.0",
      "@types/dotenv": "^8.2.3",
      "@types/express": "^5.0.3",
      "@types/jest": "^30.0.0",
      "@types/multer": "^2.0.0",
      "@types/node": "^24.3.0",
      "@types/passport": "^1.0.17",
      "@types/passport-jwt": "^4.0.1",
      "@types/socket.io": "^3.0.2",
      "@types/supertest": "^6.0.3",
      "@typescript-eslint/eslint-plugin": "^8.39.1",
      "@typescript-eslint/parser": "^8.39.1",
      "eslint": "^9.33.0",
      "eslint-config-prettier": "^10.1.8",
      "eslint-plugin-prettier": "^5.5.4",
      "globals": "^16.3.0",
      "jest": "^30.0.5",
      "prettier": "^3.6.2",
      "source-map-support": "^0.5.21",
      "supertest": "^7.1.4",
      "ts-jest": "^29.4.1",
      "ts-loader": "^9.5.2",
      "ts-node": "10.9.2",
      "tsconfig-paths": "^4.2.0",
      "typescript": "^5.5.4"
   },
   "resolutions": {
      "form-data": "^4.0.4",
      "semver": "^7.5.2",
      "cross-spawn": "^7.0.5",
      "ws": "^8.17.1",
      "engine.io": "^6.4.2",
      "socket.io-parser": "^4.2.3",
      "socket.io": "^4.6.2",
      "cookie": "^0.7.0",
      "brace-expansion": "^2.0.2",
      "micromatch": "^4.0.8",
      "@babel/helpers": "^7.26.10",
      "@babel/traverse": "^7.23.2",
      "json5": "^2.2.2",
      "path-to-regexp": "^1.9.0",
      "tmp": "^0.2.4",
      "tar": "^6.2.1",
      "braces": "^3.0.3"
   },
   "jest": {
      "moduleFileExtensions": [
         "js",
         "json",
         "ts"
      ],
      "rootDir": "src",
      "testRegex": ".*\\.spec\\.ts$",
      "transform": {
         "^.+\\.(t|j)s$": "ts-jest"
      },
      "collectCoverageFrom": [
         "**/*.(t|j)s"
      ],
      "coverageDirectory": "../coverage",
      "testEnvironment": "node"
   }
}
